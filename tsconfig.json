{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@workspace/ui/*": ["./packages/ui/*"],
      "@workspace/content/*": ["./packages/content/*"],
      "@workspace/content": ["./packages/content/index.ts"],
      "@workspace/types/*": ["./packages/types/*"],
      "@workspace/types": ["./packages/types/index.ts"],
      "@workspace/utils/*": ["./packages/utils/*"],
      "@workspace/utils": ["./packages/utils/index.ts"]
    }
  },
  "exclude": ["node_modules"]
}