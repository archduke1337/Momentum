{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@workspace/ui/*": [
        "../../packages/ui/*"
      ],
      "@workspace/content": [
        "../../packages/content/index.ts"
      ],
      "@workspace/content/*": [
        "../../packages/content/*"
      ],
      "@workspace/types": [
        "../../packages/types/index.ts"
      ],
      "@workspace/types/*": [
        "../../packages/types/*"
      ],
      "@workspace/utils": [
        "../../packages/utils/index.ts"
      ],
      "@workspace/utils/*": [
        "../../packages/utils/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
